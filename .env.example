# Snowflake Configuration
SNOWFLAKE_USER=your.email@company.com
SNOWFLAKE_ACCOUNT=ACCOUNT_ID-REGION
SNOWFLAKE_AUTHENTICATOR=externalbrowser
SNOWFLAKE_WAREHOUSE=WAREHOUSE_NAME
SNOWFLAKE_DATABASE=DATABASE_NAME
SNOWFLAKE_SCHEMA=SCHEMA_NAME

# Pendo Configuration (Product Analytics)
PENDO_API_KEY=your-api-key-uuid.region
PENDO_APP_ID=your-app-id-number

# Slack Bot Configuration (Cars Copilot)
SLACK_APP_TOKEN=xapp-1-YOUR_TOKEN_HERE
SLACK_BOT_TOKEN=xoxb-YOUR_TOKEN_HERE

# Google Sheets / Slides MCP
GOOGLE_CLIENT_ID=YOUR_CLIENT_ID.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=GOCSPX-YOUR_SECRET_HERE
GOOGLE_DRIVE_OAUTH_CREDENTIALS=/path/to/your/client_secret.json

# Roadmap Google Sheet
ROADMAP_SPREADSHEET_ID=YOUR_SPREADSHEET_ID_HERE
